# ==========================================================================
# .gitignore — minimal public archive
#
# This repository tracks ONLY what is needed for the website, documentation,
# reproducibility skeleton (code), and small dashboard-ready processed data.
# The full-resolution dataset (raw .pkl/.npz and per-test CSVs, ~140 MB) is
# published on Zenodo — see README.md. It is deliberately NOT committed here.
# ==========================================================================

# ---- Large / full-resolution data (lives on Zenodo) -----------------------
*.pkl
*.npz
# Per-test full CSVs under data/
data/raw/**/csv/
# Everything derived by the Python pipeline (regenerated from the raw data)
data/processed/
# Full data bundled only into the self-contained (Zenodo) build, never here
web_dashboard/public/data/full/

# ---- Python ---------------------------------------------------------------
venv/
.venv/
env/
ENV/
.env
env.bak/
venv.bak/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
build/
dist-python/
*.egg-info/
.eggs/

# ---- Node / React / Vite --------------------------------------------------
node_modules/
**/node_modules/
.vite/
web_dashboard/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
web_dashboard/build/

# ---- OS / editor junk -----------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*~
.idea/
.vscode/
*.swp

# ==========================================================================
# KEEP the committed production build (minimal — no bundled full data).
# dist/ is tracked; re-ignore only the heavy full-data folder inside it.
# ==========================================================================
!web_dashboard/dist/
!web_dashboard/dist/**
web_dashboard/dist/data/full/
